{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/admin", "destination": "/api/index.js" },
    { "source": "/admin/:path*", "destination": "/api/index.js" }
  ]
}
